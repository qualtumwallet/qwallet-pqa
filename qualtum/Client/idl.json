{
  "version": "0.1.0",
  "name": "qualtum",
  "instructions": [
    {
      "name": "initVault",
      "accounts": [
        { "name": "vault", "isMut": true, "isSigner": false },
        { "name": "user", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "commitment", "type": { "array": ["u8", 32] } }
      ]
    },
    {
      "name": "deposit",
      "accounts": [
        { "name": "vault", "isMut": true, "isSigner": false },
        { "name": "user", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ]
    },
    {
      "name": "withdraw",
      "accounts": [
        { "name": "vault", "isMut": true, "isSigner": false },
        { "name": "owner", "isMut": true, "isSigner": true },
        { "name": "userWallet", "isMut": true, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" },
        { "name": "secretHash", "type": { "array": ["u8", 32] } }
      ]
    }
  ],
  "accounts": [
    {
      "name": "VaultAccount",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "owner", "type": "publicKey" },
          { "name": "dilithiumCommitment", "type": { "array": ["u8", 32] } },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "InvalidDilithiumHash", "msg": "Invalid Dilithium hash" },
    { "code": 6001, "name": "InsufficientFunds", "msg": "Insufficient funds in vault" },
    { "code": 6002, "name": "Overflow", "msg": "Math overflow" }
  ]
}